# swap file from vim
**/*.swp

# generated by MacOS when finder enters a directory
**/.DS_STORE

zsh/.zsh_sessions/

homebrew/Brewfile.lock.json
# npm
configstore
gcloud
gh
# github-copilot stores a credential
github-copilot
helm
.idea
iterm2
jgit
git
htop
packer
pavucontrol.ini
qBittorrent
# rclone stores credentials in configuration
rclone

zed/prompts/

# claude - only track settings, ignore runtime data
claude/*
!claude/settings.json
!claude/settings.local.json

# Claude Code's project-local cwd marker created when run from ~/.config —
# distinct from claude/ above and contains only runtime data.
.claude/

# oh-my-claudecode runtime state
.omc/

# sops age private key — committing this defeats the entire encryption story
sops/

# bitwarden secrets local session state
bws/

# cagent first-run marker
cagent/
